---
import QuoteForm from './QuoteForm.astro';
---

<div class="quote-modal" id="quote-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="quote-modal-title">
  <div class="quote-modal-overlay" data-quote-close></div>
  <div class="quote-modal-panel">
    <button class="quote-modal-close" data-quote-close aria-label="Close form">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
        <line x1="6" y1="6" x2="18" y2="18"/>
        <line x1="18" y1="6" x2="6" y2="18"/>
      </svg>
    </button>
    <div id="quote-modal-title" class="visually-hidden">Get a free site & competitor audit</div>
    <QuoteForm />
  </div>
</div>

<style>
.quote-modal {
  position: fixed; inset: 0;
  z-index: 1000;
  display: none;
  align-items: flex-start;
  justify-content: center;
  padding: 5vh 16px;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}
.quote-modal.is-open { display: flex; }
.quote-modal-overlay {
  position: fixed; inset: 0;
  background: rgba(10, 10, 10, 0.65);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  animation: qm-fade 0.18s ease-out;
}
.quote-modal-panel {
  position: relative;
  width: 100%;
  max-width: 560px;
  animation: qm-pop 0.22s cubic-bezier(0.16, 1, 0.3, 1);
}
.quote-modal-close {
  position: absolute;
  top: -6px;
  right: -6px;
  background: var(--white);
  border: 1px solid var(--onyx);
  border-radius: 50%;
  width: 36px; height: 36px;
  display: inline-flex; align-items: center; justify-content: center;
  cursor: pointer;
  color: var(--onyx);
  box-shadow: 2px 2px 0 0 var(--onyx);
  transition: transform 0.1s ease, box-shadow 0.1s ease, background 0.15s, color 0.15s;
  z-index: 2;
  padding: 0;
}
.quote-modal-close:hover {
  transform: translate(1px, 1px);
  box-shadow: 1px 1px 0 0 var(--blaze);
  background: var(--blaze);
  color: var(--white);
  border-color: var(--blaze);
}
.visually-hidden {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
}
body.quote-open { overflow: hidden; }

@keyframes qm-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes qm-pop {
  from { opacity: 0; transform: translateY(-8px) scale(0.985); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

@media (max-width: 600px) {
  .quote-modal { padding: 3vh 12px; }
  .quote-modal-close { top: -10px; right: -10px; }
}
</style>

<script is:inline>
(function(){
  const modal = document.getElementById('quote-modal');
  if (!modal) return;

  function open() {
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('quote-open');
    // Focus the first input in the modal on next frame
    requestAnimationFrame(() => {
      const first = modal.querySelector('input, select, button.qf-submit');
      if (first) first.focus({ preventScroll: true });
    });
  }
  function close() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('quote-open');
  }

  document.addEventListener('click', e => {
    const opener = e.target.closest('[data-quote]');
    if (opener) {
      e.preventDefault();
      open();
      return;
    }
    const closer = e.target.closest('[data-quote-close]');
    if (closer && modal.contains(closer)) {
      e.preventDefault();
      close();
    }
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) {
      close();
    }
  });
})();
</script>
