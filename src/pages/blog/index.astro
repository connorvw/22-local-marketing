---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts } from '../../data/posts.js';

const featuredPost = posts.find(p => p.featured) ?? posts[0];
const otherPosts = posts.filter(p => p.slug !== featuredPost.slug);

const categories = Array.from(new Set(posts.map(p => p.category)));
const postCountByCat = Object.fromEntries(
  categories.map(c => [c, posts.filter(p => p.category === c).length])
);
// Featured post is rendered first; other posts continue numbering after it (but numbers themselves are not displayed).
---

<BaseLayout
  title="The 22 Local Marketing Blog | Marketing for home service companies"
  description="Field-tested marketing playbooks for home service companies. SEO, Google Business Profile, paid acquisition, and the parts of running the business no one writes about."
>

  <!-- ============ HERO ============ -->
  <header class="blog-hero">
    <div class="container">
      <div class="blog-hero-inner">
        <div class="eyebrow-rugged">
          <span class="eb-dash"></span>
          <span>The 22LM journal</span>
          <span class="eb-sep">·</span>
          <span>{posts.length} articles</span>
          <span class="eb-sep">·</span>
          <span>Last update {featuredPost.date}</span>
        </div>

        <div class="blog-hero-frame">
          <h1>
            Marketing that <span class="accent">actually</span><br>
            moves home service businesses.
          </h1>
        </div>

        <p class="blog-hero-sub">Real playbooks from the trenches. SEO, Google Business Profile, paid acquisition, and the operator-level decisions that make or break a local home service company.</p>

        <div class="blog-hero-actions">
          <a href="#latest" class="btn btn-primary btn-lg">Read the latest <span class="btn-arrow">→</span></a>
          <a href="/#contact" class="btn btn-secondary btn-lg" data-quote>Talk to us</a>
        </div>
      </div>
    </div>
  </header>

  <!-- ============ FEATURED ============ -->
  <section class="blog-featured flush" id="featured">
    <div class="container">
      <div class="featured-meta-row">
        <div class="eyebrow-rugged">
          <span class="eb-dash"></span>
          <span>Featured this month</span>
        </div>
        <a href={`/blog/${featuredPost.slug}/`} class="featured-quick-link">
          Read article <span class="btn-arrow">→</span>
        </a>
      </div>

      <a href={`/blog/${featuredPost.slug}/`} class="featured-card">
        <div class="featured-card-cover">
          <div class="featured-cover-tag">{featuredPost.category}</div>
          <div class="featured-cover-meta">
            <span>{featuredPost.date}</span>
            <span class="featured-cover-sep">·</span>
            <span>{featuredPost.readTime}</span>
          </div>
          <div class="featured-cover-pattern"></div>
        </div>
        <div class="featured-card-body">
          <div class="featured-eyebrow">→ Long read</div>
          <h2>{featuredPost.title}</h2>
          <p>{featuredPost.excerpt}</p>
          <span class="featured-read-cta">Open the article <span class="btn-arrow">→</span></span>
        </div>
      </a>
    </div>
  </section>

  <!-- ============ ALL POSTS ============ -->
  <section class="blog-list" id="latest">
    <div class="container">
      <div class="section-head">
        <h2>Every article. Newest first.</h2>
        <span class="desc">Written for owners, operators, and anyone running a home services brand who is tired of marketing fluff.</span>
      </div>

      <div class="post-grid">
        {otherPosts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="post-card">
            <div class="post-card-top">
              <span class="post-card-cat">{post.category}</span>
            </div>
            <h3>{post.title}</h3>
            <p>{post.excerpt}</p>
            <div class="post-card-foot">
              <span class="post-card-date">{post.date}</span>
              <span class="post-card-sep">·</span>
              <span class="post-card-read">{post.readTime}</span>
              <span class="post-card-more">Read more <span class="post-card-arrow">→</span></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CATEGORIES STRIP ============ -->
  <section class="cat-strip dark">
    <div class="container">
      <div class="section-head">
        <h2 style="color: var(--white)">Browse by topic.</h2>
        <span class="desc">Pick the part of the marketing engine you care about most.</span>
      </div>
      <div class="cat-grid">
        {categories.map((cat, i) => (
          <div class="cat-tile" style={`--cat-i:${i}`}>
            <div class="cat-tile-index">{String(i + 1).padStart(2, '0')}</div>
            <div class="cat-tile-name">{cat}</div>
            <div class="cat-tile-count">{postCountByCat[cat]} {postCountByCat[cat] === 1 ? 'article' : 'articles'}</div>
            <div class="cat-tile-rule"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="blog-cta">
    <div class="container">
      <div class="blog-cta-block">
        <div>
          <div class="cta-eyebrow">→ Free 30-minute call</div>
          <h2>Reading is good. Doing the work is better.</h2>
          <p>Every article here is built from the work we do for clients every week. If you want that work done for your business, the next move is a 30-minute call.</p>
        </div>
        <div class="blog-cta-side">
          <div class="blog-cta-points">
            <div class="cta-point"><div class="cta-point-num">→</div><div><div class="cta-point-title">No pitch deck</div><div class="cta-point-desc">A real conversation about your business, not ours.</div></div></div>
            <div class="cta-point"><div class="cta-point-num">→</div><div><div class="cta-point-title">Honest answer</div><div class="cta-point-desc">If we can't help, we say so on the call.</div></div></div>
            <div class="cta-point"><div class="cta-point-num">→</div><div><div class="cta-point-title">Audit included</div><div class="cta-point-desc">A 1-page action list, yours either way.</div></div></div>
          </div>
          <a href="/#contact" class="btn btn-primary btn-lg" data-quote>Book the call <span class="btn-arrow">→</span></a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  /* ============ BLOG HERO ============ */
  .blog-hero {
    padding: 80px 0 72px;
    position: relative;
    overflow: hidden;
    background: var(--bone);
    border-bottom: 1px solid var(--border);
  }
  .blog-hero::before {
    content: '';
    position: absolute;
    top: 0; right: -120px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(251, 86, 7, 0.10), transparent 60%);
    pointer-events: none;
  }
  .blog-hero-inner {
    position: relative; z-index: 1;
    max-width: 880px;
  }
  .blog-hero-frame {
    position: relative; display: inline-block;
    padding: 14px 0 10px;
    margin-bottom: 26px;
  }
  .blog-hero-frame::before, .blog-hero-frame::after {
    content: ''; position: absolute;
    width: 22px; height: 22px;
    border: 2px solid var(--blaze);
  }
  .blog-hero-frame::before { top: 0; left: -22px; border-right: 0; border-bottom: 0; }
  .blog-hero-frame::after  { bottom: 0; right: -22px; border-left: 0; border-top: 0; }
  .blog-hero h1 {
    font-size: 64px;
    line-height: 1.02;
    letter-spacing: -0.04em;
    font-weight: 700;
    max-width: 720px;
  }
  .blog-hero h1 .accent { color: var(--blaze); }
  .blog-hero-sub {
    font-size: 18px;
    line-height: 1.55;
    color: var(--slate);
    max-width: 560px;
    margin-bottom: 32px;
  }
  .blog-hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ============ FEATURED ============ */
  .blog-featured { padding-top: 64px !important; padding-bottom: 88px !important; }
  .featured-meta-row {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 28px;
    flex-wrap: wrap; gap: 16px;
  }
  .featured-meta-row .eyebrow-rugged { margin-bottom: 0; }
  .featured-quick-link {
    font-size: 13px;
    color: var(--onyx);
    text-decoration: none;
    font-weight: 600;
    letter-spacing: -0.01em;
    transition: color 0.18s;
  }
  .featured-quick-link:hover { color: var(--blaze); }
  .featured-quick-link:hover .btn-arrow { transform: translateX(3px); }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    background: var(--white);
    border: 1px solid var(--onyx);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 8px 8px 0 0 var(--onyx);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .featured-card:hover { transform: translate(-2px, -2px); box-shadow: 11px 11px 0 0 var(--onyx); }

  .featured-card-cover {
    background: var(--onyx);
    color: var(--white);
    padding: 36px;
    position: relative;
    overflow: hidden;
    display: flex; flex-direction: column;
    justify-content: space-between;
    min-height: 360px;
  }
  .featured-card-cover::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 80% 25%, rgba(251, 86, 7, 0.32), transparent 55%),
                radial-gradient(circle at 18% 80%, rgba(251, 86, 7, 0.18), transparent 60%);
    pointer-events: none;
  }
  .featured-cover-pattern {
    position: absolute; inset: 0;
    background-image: repeating-linear-gradient(45deg, transparent 0 26px, rgba(255,255,255,0.022) 26px 27px);
    pointer-events: none;
  }
  .featured-cover-tag {
    align-self: flex-start;
    background: var(--blaze);
    color: var(--white);
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 8px 14px;
    border-radius: 4px;
    position: relative; z-index: 1;
  }
  .featured-cover-meta {
    font-size: 12px;
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: 600;
    position: relative; z-index: 1;
    display: flex; align-items: center; gap: 10px;
  }
  .featured-cover-sep { color: rgba(255,255,255,0.3); }

  .featured-card-body {
    padding: 44px 48px;
    display: flex; flex-direction: column;
    justify-content: center;
  }
  .featured-eyebrow {
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    color: var(--blaze);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 18px;
    font-weight: 700;
  }
  .featured-card-body h2 {
    font-size: 36px;
    line-height: 1.08;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--onyx);
  }
  .featured-card-body p {
    font-size: 16px;
    color: var(--slate);
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .featured-read-cta {
    font-size: 14px;
    color: var(--blaze);
    font-weight: 700;
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-transform: uppercase;
    font-family: 'Sora', sans-serif;
  }
  .featured-card:hover .featured-read-cta .btn-arrow { transform: translateX(3px); }

  /* ============ POST GRID ============ */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .post-card {
    background: var(--white);
    border: 1px solid var(--onyx);
    border-radius: 10px;
    padding: 28px 28px 26px;
    box-shadow: 4px 4px 0 0 var(--onyx);
    text-decoration: none;
    color: inherit;
    display: flex; flex-direction: column;
    transition: transform 0.15s, box-shadow 0.15s;
    position: relative;
    overflow: hidden;
  }
  .post-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 7px 0 0 var(--onyx);
  }

  .post-card-top {
    display: flex; align-items: center;
    margin-bottom: 18px;
    gap: 10px;
  }
  .post-card-cat {
    font-family: 'Sora', sans-serif;
    font-size: 10px;
    color: var(--onyx);
    background: var(--bone);
    border: 1px solid var(--border-strong);
    padding: 5px 9px;
    border-radius: 4px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .post-card h3 {
    font-size: 19px;
    line-height: 1.22;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: var(--onyx);
    margin-bottom: 12px;
  }
  .post-card p {
    font-size: 14px;
    color: var(--slate);
    line-height: 1.55;
    margin-bottom: 22px;
    flex: 1;
  }
  .post-card-foot {
    display: flex; align-items: center; gap: 8px;
    font-size: 12px;
    color: var(--slate);
    padding-top: 16px;
    border-top: 1px dashed var(--border);
    font-family: 'Sora', sans-serif;
    letter-spacing: 0.02em;
  }
  .post-card-sep { color: var(--border-strong); }
  .post-card-more {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--blaze);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: 'Sora', sans-serif;
  }
  .post-card-arrow {
    color: var(--blaze);
    font-size: 16px;
    font-weight: 700;
    transition: transform 0.2s;
    display: inline-block;
  }
  .post-card:hover .post-card-arrow { transform: translateX(4px); }

  /* ============ CATEGORIES STRIP ============ */
  .cat-strip { padding: 88px 0; }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .cat-tile {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 10px;
    padding: 28px 22px 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
  }
  .cat-tile:hover {
    border-color: var(--blaze);
    background: rgba(251, 86, 7, 0.06);
  }
  .cat-tile-index {
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    color: var(--blaze);
    letter-spacing: 0.18em;
    margin-bottom: 16px;
    font-weight: 700;
  }
  .cat-tile-name {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--white);
    margin-bottom: 8px;
  }
  .cat-tile-count {
    font-size: 12px;
    color: var(--slate-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .cat-tile-rule {
    margin-top: 22px;
    height: 2px;
    background:
      linear-gradient(to right, var(--blaze) 0 32px, transparent 32px 36px,
      rgba(255,255,255,0.10) 36px 100%);
  }

  /* ============ CTA ============ */
  .blog-cta { padding: 88px 0; background: var(--bone); }
  .blog-cta-block {
    background: var(--onyx);
    color: var(--white);
    border-radius: 14px;
    padding: 56px 48px;
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .blog-cta-block::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 88% 20%, rgba(251,86,7,0.22), transparent 60%);
    pointer-events: none;
  }
  .blog-cta-block > * { position: relative; z-index: 1; }
  .blog-cta-block .cta-eyebrow {
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    color: var(--blaze);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 18px;
    font-weight: 700;
  }
  .blog-cta-block h2 {
    font-size: 38px;
    line-height: 1.05;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--white);
  }
  .blog-cta-block p {
    font-size: 16px;
    color: var(--slate-light);
    line-height: 1.6;
    max-width: 460px;
    margin-bottom: 0;
  }
  .blog-cta-side { display: grid; gap: 26px; }
  .blog-cta-points { display: grid; gap: 16px; }
  .blog-cta-points .cta-point { display: flex; gap: 14px; align-items: flex-start; }
  .blog-cta-points .cta-point-num { font-size: 18px; color: var(--blaze); flex-shrink: 0; padding-top: 2px; }
  .blog-cta-points .cta-point-title { font-size: 15px; font-weight: 600; color: var(--white); margin-bottom: 4px; }
  .blog-cta-points .cta-point-desc { font-size: 13px; color: var(--slate-light); line-height: 1.5; }
  .blog-cta-side .btn { align-self: flex-start; }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 1100px) {
    .post-grid { grid-template-columns: repeat(2, 1fr); }
    .cat-grid  { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 1000px) {
    .blog-hero h1 { font-size: 48px; }
    .featured-card { grid-template-columns: 1fr; }
    .featured-card-cover { min-height: 200px; }
    .featured-card-body { padding: 32px; }
    .featured-card-body h2 { font-size: 28px; }
    .blog-cta-block { grid-template-columns: 1fr; padding: 40px 32px; }
    .blog-cta-block h2 { font-size: 30px; }
  }
  @media (max-width: 700px) {
    .post-grid { grid-template-columns: 1fr; }
    .cat-grid  { grid-template-columns: repeat(2, 1fr); }
    .blog-hero { padding: 56px 0; }
    .blog-hero h1 { font-size: 36px; }
  }
</style>
