@media (max-width: 900px) { .page-cta-grid { grid-template-columns: 1fr; gap: 32px; } }
@media (max-width: 980px) {
  .stats-bar { grid-template-columns: repeat(2, 1fr); }
  .stats-bar .stat:nth-child(2) { border-right: none; }
  .stats-bar .stat:nth-child(-n+2) { border-bottom: 1px solid #1f1f1f; }
  .case-head { grid-template-columns: 1fr; gap: 32px; }
  .case-side-stats { grid-template-rows: auto; grid-template-columns: repeat(3, 1fr); }
