  .container { padding: 0 22px; }
  .case-side-stats { grid-template-columns: 1fr; }
  .stats-bar { grid-template-columns: 1fr; }
  .stats-bar .stat { border-right: none; border-bottom: 1px solid #1f1f1f; }
  .stats-bar .stat:last-child { border-bottom: none; }
}
</style>

<script is:inline>
// ===== BEFORE / AFTER SLIDER =====
function initBA(el) {
  const after = el.querySelector('.ba-after');
  const handle = el.querySelector('.ba-handle');
  let dragging = false;

  function setPosition(clientX) {
    const rect = el.getBoundingClientRect();
    let pct = ((clientX - rect.left) / rect.width) * 100;
    pct = Math.max(0, Math.min(100, pct));
    after.style.clipPath = `inset(0 ${100 - pct}% 0 0)`;
    handle.style.left = pct + '%';
  }

  function onPointerDown(e) {
    dragging = true;
    el.style.cursor = 'grabbing';
    const x = e.touches ? e.touches[0].clientX : e.clientX;
    setPosition(x);
  }
  function onPointerMove(e) {
    if (!dragging) return;
    const x = e.touches ? e.touches[0].clientX : e.clientX;
    setPosition(x);
    if (e.touches) e.preventDefault();
  }
  function onPointerUp() {
    dragging = false;
    el.style.cursor = 'ew-resize';
  }

  el.addEventListener('mousedown', onPointerDown);
  el.addEventListener('touchstart', onPointerDown, { passive: true });
  document.addEventListener('mousemove', onPointerMove);
  document.addEventListener('touchmove', onPointerMove, { passive: false });
  document.addEventListener('mouseup', onPointerUp);
  document.addEventListener('touchend', onPointerUp);

  // Start at 50%
  const rect = el.getBoundingClientRect();
  setPosition(rect.left + rect.width / 2);
}

document.querySelectorAll('[data-ba]').forEach(initBA);

// ===== CAROUSEL =====
function initCarousel(el) {
  const track = el.querySelector('.car-track');
  const slides = track.querySelectorAll('.car-slide');
  const prev = el.querySelector('.car-prev');
  const next = el.querySelector('.car-next');
  const dotsContainer = el.querySelector('.car-dots');
  const counter = el.closest('.car-section').querySelector('[data-counter]');
  const total = slides.length;
  let i = 0;

  // Build dots
  for (let n = 0; n < total; n++) {
    const dot = document.createElement('button');
    dot.className = 'car-dot' + (n === 0 ? ' active' : '');
    dot.setAttribute('aria-label', 'Slide ' + (n + 1));
    dot.addEventListener('click', () => go(n));
    dotsContainer.appendChild(dot);
  }
  const dots = dotsContainer.querySelectorAll('.car-dot');

  function updateCounter() {
    if (counter) counter.textContent = String(i + 1).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');
  }

  function go(n) {
    i = (n + total) % total;
    track.style.transform = 'translateX(-' + (i * 100) + '%)';
    dots.forEach((d, idx) => d.classList.toggle('active', idx === i));
    updateCounter();
  }

  prev.addEventListener('click', () => go(i - 1));
  next.addEventListener('click', () => go(i + 1));

  // Keyboard nav when carousel is hovered
  el.addEventListener('mouseenter', () => el.dataset.focus = '1');
  el.addEventListener('mouseleave', () => delete el.dataset.focus);

  // Touch swipe
  let startX = 0;
  let startY = 0;
  let swiping = false;
  el.addEventListener('touchstart', e => {
    startX = e.touches[0].clientX;
    startY = e.touches[0].clientY;
    swiping = true;
  }, { passive: true });
  el.addEventListener('touchend', e => {
    if (!swiping) return;
    const dx = e.changedTouches[0].clientX - startX;
    const dy = e.changedTouches[0].clientY - startY;
    if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) {
      go(i + (dx < 0 ? 1 : -1));
    }
    swiping = false;
  });

  updateCounter();
}

document.querySelectorAll('[data-car]').forEach(initCarousel);

// Global keyboard nav for whichever carousel is hovered
document.addEventListener('keydown', e => {
  const focused = document.querySelector('[data-car][data-focus]');
  if (!focused) return;
  if (e.key === 'ArrowRight') focused.querySelector('.car-next').click();
  else if (e.key === 'ArrowLeft') focused.querySelector('.car-prev').click();
});

// ===== FILTER =====
const filterBtns = document.querySelectorAll('.filter-btn');
const cases = document.querySelectorAll('.case-study');
filterBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    filterBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const filter = btn.dataset.filter;
    cases.forEach(c => {
      c.classList.toggle('hidden', filter !== 'all' && c.dataset.vertical !== filter);
    });
  });
});
</script>

</BaseLayout>
