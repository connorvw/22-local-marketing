  flex-wrap: wrap; gap: 12px;
  margin-bottom: 16px;
}
.car-section-head h3 {
  font-size: 13px; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--slate);
}
.car-section-head .car-counter {
  font-size: 12px; color: var(--slate-light);
  font-weight: 500;
}

.car {
  position: relative;
  border: 1px solid var(--onyx);
  border-radius: 12px;
  overflow: hidden;
  background: var(--white);
  box-shadow: 6px 6px 0 0 var(--onyx);
}
.car-viewport { overflow: hidden; }
.car-track {
  display: flex;
  transition: transform 0.55s cubic-bezier(0.65, 0, 0.35, 1);
}
.car-slide {
  flex: 0 0 100%;
  width: 100%;
  aspect-ratio: 16 / 9;
  background: var(--bone);
  position: relative;
}
.car-slide-label {
  position: absolute; top: 14px; left: 14px;
  background: var(--onyx); color: var(--white);
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 5px 10px; border-radius: 3px;
  z-index: 4;
}

.car-controls {
  position: absolute; bottom: 14px; right: 14px;
  display: flex; gap: 8px;
  z-index: 5;
}
.car-btn {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: var(--white);
  border: 1px solid var(--onyx);
  font-family: inherit; font-size: 16px; font-weight: 600;
  cursor: pointer;
  display: inline-flex; align-items: center; justify-content: center;
  box-shadow: 2px 2px 0 0 var(--onyx);
  transition: all 0.15s;
  color: var(--onyx);
}
.car-btn:hover {
  background: var(--blaze); color: var(--white);
  border-color: var(--blaze);
}
.car-dots {
  position: absolute; bottom: 22px; left: 50%;
  transform: translateX(-50%);
  display: flex; gap: 6px;
  z-index: 5;
}
.car-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: rgba(0,0,0,0.25);
  border: none; padding: 0; cursor: pointer;
  transition: all 0.3s;
}
.car-dot.active {
  background: var(--blaze);
  width: 24px; border-radius: 4px;
}

