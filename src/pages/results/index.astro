          <div class="site-mock">
            <div class="site-chrome">
              <div class="dots"><span class="r"></span><span class="y"></span><span class="g"></span></div>
              <div class="url">fonvilletreeservice.com</div>
            </div>
            <div class="site-body site-after">
              <div class="after-nav">
                <span class="brand"><span class="brand-dot"></span>Fonville Tree Service</span>
                <span class="nav-links"><span>Services</span><span>Locations</span><span>About</span><span>Reviews</span></span>
