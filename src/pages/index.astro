---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteForm from '../components/QuoteForm.astro';

const trades = [
  { key: 'tree-services', name: 'Tree services', services: ['Removal', 'Pruning', 'Stump grinding', 'Emergency response'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L6 10h3l-4 6h4l-4 6h14l-4-6h4l-4-6h3z"/><line x1="12" y1="22" x2="12" y2="18"/></svg>' },
  { key: 'land-management', name: 'Land management', services: ['Forestry mulching', 'Land clearing', 'Brush removal', 'Grading'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20l5-9 4 5 3-4 6 8z"/><circle cx="18" cy="6" r="1.5"/></svg>' },
  { key: 'electrical', name: 'Electrical', services: ['Service calls', 'Repairs', 'Panel upgrades', 'New construction'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 4 14 11 14 10 22 20 9 13 9 13 2"/></svg>' },
  { key: 'plumbing', name: 'Plumbing', services: ['Emergency service', 'Drain cleaning', 'Water heaters', 'Repipes'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5c4 5.5 6.5 9 6.5 12.5a6.5 6.5 0 0 1-13 0c0-3.5 2.5-7 6.5-12.5z"/></svg>' },
  { key: 'hvac', name: 'HVAC', services: ['Service', 'Installation', 'Maintenance plans', 'Heat pumps'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h13a3 3 0 1 0-3-3"/><path d="M3 16h17a3 3 0 1 1-3 3"/><path d="M3 12h11a3 3 0 1 1-3 3"/></svg>' },
  { key: 'landscaping', name: 'Landscaping', services: ['Design', 'Installation', 'Hardscapes', 'Maintenance'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3 4.8 15.4-4.4 18.8z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>' },
  { key: 'roofing', name: 'Roofing', services: ['Replacement', 'Repair', 'Storm restoration', 'Gutters'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8"/><path d="M5 9.5V21h14V9.5"/><path d="M9 21v-6h6v6"/></svg>' },
  { key: 'grading', name: 'Grading & excavation', services: ['Site prep', 'Driveways', 'Drainage', 'Demolition'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20l3-7 4 2 3-5 4 3v7"/><circle cx="6.5" cy="20" r="1.5"/><circle cx="17.5" cy="20" r="1.5"/></svg>' },
  { key: 'garage-doors', name: 'Garage doors', services: ['Spring repair', 'Opener install', 'Panel replacement', 'New install'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="1"/><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="13" x2="21" y2="13"/><line x1="3" y1="18" x2="21" y2="18"/></svg>' },
  { key: 'pressure-washing', name: 'Pressure washing', services: ['Residential', 'Fleet washing', 'HOA contracts', 'Soft wash'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v3a3 3 0 0 0 3 3h3"/><rect x="13" y="11" width="9" height="3" rx="0.5"/><path d="M3 14l5-3"/><path d="M3 17l5-2"/><path d="M3 20l5-1"/></svg>' },
  { key: 'fencing', name: 'Fencing', services: ['Wood', 'Vinyl', 'Chain link', 'Repairs'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="18" x2="21" y2="18"/><line x1="3" y1="14" x2="21" y2="14"/><path d="M5 8l1-3 1 3v14"/><path d="M9 8l1-3 1 3v14"/><path d="M13 8l1-3 1 3v14"/><path d="M17 8l1-3 1 3v14"/></svg>' },
  { key: 'concrete', name: 'Concrete & masonry', services: ['Driveways', 'Patios', 'Retaining walls', 'Repairs'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="0.5"/><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="16" x2="21" y2="16"/></svg>' },
  { key: 'house-painters', name: 'House painters', services: ['Interior', 'Exterior', 'Cabinet refinishing', 'Soft wash + paint'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="13" height="5" rx="1"/><path d="M16 6.5h4"/><path d="M20 5v3"/><path d="M10 9v3"/><rect x="7" y="12" width="6" height="9" rx="1"/></svg>' },
];

const tradesRow2 = [...trades.slice(4), ...trades.slice(0, 4)];
const tradesRow3 = [...trades.slice(8), ...trades.slice(0, 8)];
---

<BaseLayout title="22 Local Marketing | Home services marketing that grows revenue">

<!-- ============ HERO ============ -->
<header class="hero">
  <div class="container hero-grid">
    <div>
      <div class="eyebrow-rugged">
        <span class="eb-dash"></span>
        <span>HOME SERVICES MARKETING</span>
        <span class="eb-sep">·</span>
        <span>EST. 2026</span>
      </div>
      <div class="hero-frame">
        <h1>The marketing engine for serious <span class="accent">home service</span> companies.</h1>
      </div>
      <p class="hero-sub">We build the websites, SEO, and paid campaigns that move trades businesses from booked-out-by-luck to booked-out-by-system. Every dollar tied back to revenue.</p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary btn-lg" data-quote>Get a free audit <span class="btn-arrow">→</span></a>
        <a href="#services" class="btn btn-secondary btn-lg">See what we do</a>
      </div>
    </div>

    <QuoteForm />
  </div>
</header>

<!-- ============ STATS + VIDEO ============ -->
<section class="flush" style="padding-top: 0; border-top: 0;">
  <div class="container">
    <div class="stats-row">
      <div class="stats-tag">Average per client, every month</div>
      <div class="stats">
        <div class="stat"><div class="stat-label">Phone calls</div><div class="stat-value">60+</div><div class="stat-desc">Per client each month, across Google, ads, and search</div></div>
        <div class="stat"><div class="stat-label">Form leads</div><div class="stat-value">40+</div><div class="stat-desc">Web form submissions per client, every month</div></div>
        <div class="stat"><div class="stat-label">Leads per month</div><div class="stat-value">90+</div><div class="stat-desc">New leads we average per client, every month</div></div>
        <div class="stat"><div class="stat-label">Our Google rating</div><div class="stat-value">5.0★</div><div class="stat-desc">What the businesses we work with rate us</div></div>
      </div>
      <!-- Overview walkthrough video hidden for now
      <div class="video-placeholder">
        <div class="video-thumb">
          <div class="video-play">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg>
          </div>
          <div class="video-hint">Overview walkthrough goes here</div>
          <div class="video-meta">Video slot 02 · placeholder</div>
        </div>
      </div>
      -->
    </div>
  </div>
</section>

<!-- ============ SERVICES ============ -->
<section id="services">
  <div class="container">
    <div class="section-head">
      <h2>One team. The whole marketing stack.</h2>
      <span class="desc">We run SEO, paid, web, and reporting under one roof so nothing falls between the cracks.</span>
    </div>
    <div class="svc-grid">
      <div class="svc-card">
        <div class="svc-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg></div>
        <div class="svc-title">Local SEO</div>
        <div class="svc-body">Map pack rankings, GBP optimization, and content engineered to win every relevant search in your service area.</div>
        <ul class="svc-features"><li>Google Business Profile build-out</li><li>Service + location page architecture</li><li>Review velocity and reputation</li><li>Citations, schema, and technical SEO</li></ul>
      </div>
      <div class="svc-card">
        <div class="svc-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 3 5-7"/></svg></div>
        <div class="svc-title">Paid Advertising</div>
        <div class="svc-body">Google Ads, LSA, and Meta Ads measured against revenue, not clicks. Built to fill calendar gaps fast.</div>
        <ul class="svc-features"><li>Google Search, Performance Max, and Meta Ads</li><li>Local Services Ads management</li><li>Call tracking and attribution</li><li>Weekly budget pacing reports</li></ul>
      </div>
      <div class="svc-card">
        <div class="svc-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18"/><path d="M8 14h3"/></svg></div>
        <div class="svc-title">Website builds</div>
        <div class="svc-body">Fast, conversion-focused sites that look like the top 1% of your industry. Real photos, real content, no templates that scream template.</div>
        <ul class="svc-features"><li>Full custom design and copy</li><li>Service and city page coverage</li><li>Forms wired to your CRM</li><li>Fast hosting on a global edge network</li></ul>
      </div>
      <div class="svc-card">
        <div class="svc-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 2v10l7 4"/></svg></div>
        <div class="svc-title">Google Business Profile</div>
        <div class="svc-body">Geotagged posts, photos, and Q&A maintenance that keep your profile active and visible in the map pack week after week.</div>
        <ul class="svc-features"><li>Weekly posts with real job photos</li><li>Category and service optimization</li><li>Review responses and reporting</li><li>Spam review removal workflow</li></ul>
      </div>
      <div class="svc-card">
        <div class="svc-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div>
        <div class="svc-title">AI SEO</div>
        <div class="svc-body">Content, schema, and entity signals tuned for ChatGPT, Gemini, and Google's AI Overviews. Built so AI tools surface your business when homeowners ask for service in your area.</div>
        <ul class="svc-features"><li>AI-tuned service and location page rewrites</li><li>Schema markup and entity-linked structured data</li><li>Brand mentions and citation building</li><li>Visibility tracking across ChatGPT, Gemini, and AI Overviews</li></ul>
      </div>
      <div class="svc-card">
        <div class="svc-icon"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 3h7v7H3z"/><path d="M14 3h7v7h-7z"/><path d="M14 14h7v7h-7z"/><path d="M3 14h7v7H3z"/></svg></div>
        <div class="svc-title">Reporting & strategy</div>
        <div class="svc-body">Monthly PDF reports tied to leads and revenue. Real strategy calls, not screenshot tours of vanity metrics.</div>
        <ul class="svc-features"><li>Branded monthly performance PDFs</li><li>ROI math built into every report</li><li>Strategy sessions every 60 days</li><li>Always-on direct email access</li></ul>
      </div>
    </div>
  </div>
</section>

<!-- ============ PROCESS ============ -->
<section id="process">
  <div class="container">
    <div class="section-head">
      <h2>How a campaign comes together.</h2>
      <span class="desc">A clear path from first call to first lead, then onward.</span>
    </div>
    <div class="process">
      <div class="step"><div class="step-num">01</div><div class="step-title">Audit</div><div class="step-body">We dig into your site, GBP, ads, and reviews. One-page action list within 48 hours.</div></div>
      <div class="step"><div class="step-num">02</div><div class="step-title">Strategy</div><div class="step-body">We pick the channels and pages that move the needle in your market. Nothing busywork.</div></div>
      <div class="step"><div class="step-num">03</div><div class="step-title">Build</div><div class="step-body">Website, GBP, and ad accounts get built or rebuilt to the standard your competitors aren't holding.</div></div>
      <div class="step"><div class="step-num">04</div><div class="step-title">Launch</div><div class="step-body">Everything goes live on the same day. Tracking, forms, and call attribution wired before traffic hits.</div></div>
      <div class="step"><div class="step-num">05</div><div class="step-title">Optimize</div><div class="step-body">Weekly tweaks, monthly reports, quarterly strategy. We chase the numbers, not the trends.</div></div>
    </div>
  </div>
</section>

<!-- ============ INDUSTRIES ============ -->
<section id="industries" class="industries-dark">
  <div class="container">
    <div class="section-head">
      <h2>Built for the trades that work.</h2>
      <span class="desc">We specialize in service businesses where the lead comes from a phone call and the job happens at a property.</span>
    </div>
  </div>

  <div class="marquee-d">
    <div class="md-row md-row-1">
      {[...trades, ...trades].map(t => (
        <a href="#contact" class="md-tile" data-quote>
          <span class="md-tile-icon" set:html={t.icon}></span>
          <span class="md-tile-text">
            <span class="md-tile-name">{t.name}</span>
            <span class="md-tile-services">{t.services.slice(0, 2).join(' · ')}</span>
          </span>
        </a>
      ))}
    </div>
    <div class="md-row md-row-2">
      {[...tradesRow2, ...tradesRow2].map(t => (
        <a href="#contact" class="md-tile" data-quote>
          <span class="md-tile-icon" set:html={t.icon}></span>
          <span class="md-tile-text">
            <span class="md-tile-name">{t.name}</span>
            <span class="md-tile-services">{t.services.slice(0, 2).join(' · ')}</span>
          </span>
        </a>
      ))}
    </div>
    <div class="md-row md-row-3">
      {[...tradesRow3, ...tradesRow3].map(t => (
        <a href="#contact" class="md-tile" data-quote>
          <span class="md-tile-icon" set:html={t.icon}></span>
          <span class="md-tile-text">
            <span class="md-tile-name">{t.name}</span>
            <span class="md-tile-services">{t.services.slice(0, 2).join(' · ')}</span>
          </span>
        </a>
      ))}
    </div>
  </div>

  <div class="container industries-foot">
    <a href="#contact" class="btn btn-primary btn-lg" data-quote>Build a campaign for your trade <span class="btn-arrow">→</span></a>
  </div>

</section>

<!-- ============ RESULTS ============ -->
<section id="results" class="dark">
  <div class="container">
    <div class="section-head">
      <h2 style="color: var(--white)">Numbers we work for.</h2>
      <span class="desc">Pulled from active client campaigns over the last 12 months.</span>
    </div>
    <div class="results-grid">
      <div class="results-metrics">
        <div class="metric-card"><div class="metric-label">Google impressions</div><div class="metric-value">17,000+</div><div class="metric-desc">For a single client in a 90-day window (Mar to May 2026).</div></div>
        <div class="metric-card"><div class="metric-label">Queries ranking</div><div class="metric-value">1,000+</div><div class="metric-desc">Search terms the same client now appears for on Google.</div></div>
        <div class="metric-card"><div class="metric-label">Top-3 rankings</div><div class="metric-value">160+</div><div class="metric-desc">Keywords this client holds in Google's top three.</div></div>
      </div>
      <div class="case-card">
        <div class="case-eyebrow">[ Case study · 6 months ]</div>
        <div class="case-title">Land management company</div>
        <div class="case-meta">Northwest Ohio · Land clearing, forestry mulching, and grading</div>
        <div class="case-body">A newer land management company came to us with almost no search presence. We built the site, built out the Google Business Profile, and turned Google search into a real lead channel. Inside six months they rank for over 1,000 queries, pull more than 17,000 Google impressions a quarter, and hold 160-plus keywords in Google's top three.</div>
        <div class="case-stats">
          <div class="case-stat"><div class="case-stat-value">17K</div><div class="case-stat-label">Impressions / 90 days</div></div>
          <div class="case-stat"><div class="case-stat-value">1,000+</div><div class="case-stat-label">Keywords ranking</div></div>
          <div class="case-stat"><div class="case-stat-value">160+</div><div class="case-stat-label">Top-3 rankings</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ============ REVIEWS ============ -->
<section id="reviews">
  <div class="container">
    <div class="section-head">
      <h2>What clients actually say.</h2>
      <span class="desc">Real reviews from real owners we work with every week.</span>
    </div>
    <div class="review-grid">
      <div class="review"><div class="review-stars">★★★★★</div><div class="review-quote">"Top marketing company for the tree service industry. Trust him to build your website and do your SEO if you are a tree company."</div><div class="review-author"><div class="review-avatar">BK</div><div class="review-meta"><div class="review-name">Ben Kleman</div><div class="review-company">Verified Google review</div></div></div></div>
      <div class="review"><div class="review-stars">★★★★★</div><div class="review-quote">"Connor is the man. Very responsive and he knows his stuff. He has helped my business grow more than I ever imagined. 10/10 would recommend."</div><div class="review-author"><div class="review-avatar">BF</div><div class="review-meta"><div class="review-name">Brice Fonville</div><div class="review-company">Verified Google review</div></div></div></div>
      <div class="review"><div class="review-stars">★★★★★</div><div class="review-quote">"Super service, very easy to work with. Connor is very knowledgeable, patient and best of all isn't trying to push services you don't need. Here's to the beginning of a long business relationship."</div><div class="review-author"><div class="review-avatar">RR</div><div class="review-meta"><div class="review-name">Robert Rangel</div><div class="review-company">Verified Google review</div></div></div></div>
      <div class="review"><div class="review-stars">★★★★★</div><div class="review-quote">"The knowledge he brings is unmatched to any other company I had a consultation with. For our project he was very open and explained the process simply so it was easy to follow."</div><div class="review-author"><div class="review-avatar">MV</div><div class="review-meta"><div class="review-name">Maximilian Van Dessel</div><div class="review-company">Verified Google review</div></div></div></div>
      <div class="review"><div class="review-stars">★★★★★</div><div class="review-quote">"Highly recommend Connor. Professional, extremely talented, and detail oriented. He focuses on your needs and creates a custom design."</div><div class="review-author"><div class="review-avatar">MY</div><div class="review-meta"><div class="review-name">Matt Yoder</div><div class="review-company">Verified Google review</div></div></div></div>
      <div class="review"><div class="review-stars">★★★★★</div><div class="review-quote">"Connor's attention to detail and constant communication have made him a joy to work with. I am extremely happy for the work he has done for me and hope to have a long, lasting relationship."</div><div class="review-author"><div class="review-avatar">DS</div><div class="review-meta"><div class="review-name">Dawn Sulflow</div><div class="review-company">Verified Google review</div></div></div></div>
    </div>
    <div class="review-summary">
      <div class="review-sum-left">
        <div class="review-sum-score">5.0</div>
        <div><div class="review-sum-stars">★★★★★</div><div class="review-sum-text">Across 36 verified 5-star Google reviews</div></div>
      </div>
      <a href="https://g.page/r/CQmMJquJoYTrEAE/review" class="btn btn-secondary" target="_blank" rel="noopener">See more reviews →</a>
    </div>
  </div>
</section>

<!-- ============ CLIENT VIDEO ============ -->
<section id="client-video">
  <div class="container">
    <div class="section-head">
      <h2>Hear it from a client.</h2>
      <span class="desc">An unscripted look at what it's like to work with us, straight from an owner we serve.</span>
    </div>
    <div class="video-placeholder">
      <button type="button" class="video-thumb video-thumb-yt" data-video-id="WAsSn4930ew" data-start="1" aria-label="Play client testimonial video">
        <img class="yt-poster" src="https://i.ytimg.com/vi/WAsSn4930ew/maxresdefault.jpg" alt="" loading="lazy">
        <span class="video-play"><svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg></span>
      </button>
    </div>
  </div>
</section>

<!-- ============ ABOUT ============ -->
<section id="about" style="background: var(--white)">
  <div class="container">
    <div class="about-grid">
      <div class="about-copy">
        <div class="section-head" style="margin-bottom: 20px">
          <h2>Why owners hire us.</h2>
        </div>
        <h3>Marketing built around the work, not the retainer.</h3>
        <p>22 Local Marketing was built because the agency industry kept selling the same recycled retainer to home service owners who deserved better. Generic templates, vanity dashboards, monthly invoices, no accountability for revenue.</p>
        <p>We do the opposite. We specialize in home services and nothing else, so the playbook is sharp by the time it reaches you. Every client gets a website that competes with the top of the industry, an SEO program that earns rankings the right way, and paid campaigns measured against booked jobs. If the math doesn't work, we tell you. If something's broken, we fix it before you notice.</p>
        <div class="about-bullets">
          <div class="about-bullet"><div class="about-bullet-tick"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg></div><div>No long contracts. Month to month, always.</div></div>
          <div class="about-bullet"><div class="about-bullet-tick"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg></div><div>You own everything we build. Site, GBP, accounts.</div></div>
          <div class="about-bullet"><div class="about-bullet-tick"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg></div><div>Real photos, real copy, no templates.</div></div>
          <div class="about-bullet"><div class="about-bullet-tick"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><polyline points="20 6 9 17 4 12"/></svg></div><div>One direct line of contact. Not a ticket queue.</div></div>
        </div>
        <a href="#contact" class="btn btn-primary btn-lg" data-quote>Book a strategy call <span class="btn-arrow">→</span></a>
      </div>
      <div class="about-card">
        <div class="about-card-eyebrow">→ Founder</div>
        <div class="about-photo"><img src="/founder.png" alt="Connor Dann, founder of 22 Local Marketing" loading="lazy"></div>
        <div class="about-name">Connor Dann</div>
        <div class="about-role">Founder · 22 Local Marketing</div>
