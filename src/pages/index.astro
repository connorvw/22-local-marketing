.cta-block h2 { font-size: 42px; letter-spacing: -0.04em; font-weight: 700; line-height: 1; margin-bottom: 16px; color: var(--white); }
.cta-block p { font-size: 16px; color: var(--slate-light); margin-bottom: 26px; max-width: 460px; }
.cta-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.cta-actions .btn-secondary { background: transparent; color: var(--white); border-color: rgba(255,255,255,0.25); }
.cta-actions .btn-secondary:hover { border-color: var(--white); }
.cta-points { display: grid; gap: 16px; }
.cta-point { display: flex; gap: 14px; align-items: flex-start; }
.cta-point-num { font-size: 18px; color: var(--blaze); line-height: 1; flex-shrink: 0; padding-top: 2px; }
.cta-point-title { font-size: 15px; font-weight: 600; color: var(--white); margin-bottom: 4px; }
.cta-point-desc { font-size: 13px; color: var(--slate-light); line-height: 1.5; }

/* ===== RESPONSIVE ===== */
@media (max-width: 1000px) {
  .hero-grid, .results-grid, .about-grid, .cta-block, .stats-row { grid-template-columns: 1fr; gap: 32px; }
  .stats, .svc-grid, .review-grid { grid-template-columns: repeat(2, 1fr); }
  .stats-row .video-thumb { aspect-ratio: 16 / 9; min-height: 0; }
  .stat:nth-child(2) { border-right: 0; }
  .stat:nth-child(1), .stat:nth-child(2) { border-bottom: 1px solid var(--border); }
  .process { grid-template-columns: repeat(2, 1fr); }
  .process::before { display: none; }
  .hero h1 { font-size: 44px; }
  .cta-block h2 { font-size: 32px; }
  .cta-block { padding: 40px 28px; }
}
@media (max-width: 600px) {
  .stats, .svc-grid, .review-grid, .process { grid-template-columns: 1fr; }
  .stat { border-right: 0; border-bottom: 1px solid var(--border); }
  .stat:last-child { border-bottom: 0; }
  .hero h1 { font-size: 36px; }
  .hero { padding: 64px 0 48px; }
  .hero-actions .btn, .cta-actions .btn { width: 100%; justify-content: center; }
  .case-stats { grid-template-columns: 1fr; }
}
</style>

<script is:inline>
// FAQ toggles
document.querySelectorAll('.faq-q').forEach(btn => {
  btn.addEventListener('click', () => btn.parentElement.classList.toggle('open'));
});

// YouTube facade
document.querySelectorAll('.video-thumb-yt').forEach(btn => {
  btn.addEventListener('click', () => {
    const id = btn.dataset.videoId;
    const start = btn.dataset.start || '0';
    const iframe = document.createElement('iframe');
    iframe.className = 'yt-iframe';
    iframe.src = 'https://www.youtube-nocookie.com/embed/' + id + '?autoplay=1&start=' + start + '&rel=0';
    iframe.title = 'Client testimonial video';
    iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share');
    iframe.setAttribute('allowfullscreen', '');
    btn.parentNode.replaceChild(iframe, btn);
  }, { once: true });
});
</script>

</BaseLayout>
