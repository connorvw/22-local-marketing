---
import BaseLayout from '../layouts/BaseLayout.astro';

const trades = [
  { key: 'tree-services', name: 'Tree services', tagline: 'Highest-intent vertical in home services. Emergency work alone usually pays for the marketing.', services: ['Removal', 'Pruning', 'Stump grinding', 'Emergency'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L6 10h3l-4 6h4l-4 6h14l-4-6h4l-4-6h3z"/><line x1="12" y1="22" x2="12" y2="18"/></svg>' },
  { key: 'land-management', name: 'Land management', tagline: 'Big-ticket jobs with low search competition. The right pages and ads can dominate a 60-mile radius.', services: ['Forestry mulching', 'Clearing', 'Grading'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 20l5-9 4 5 3-4 6 8z"/><circle cx="18" cy="6" r="1.5"/></svg>' },
  { key: 'electrical', name: 'Electrical', tagline: 'Mix of emergency, service, and big install work. Clear service pages convert calls fast.', services: ['Service', 'Repairs', 'Panel upgrades'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 4 14 11 14 10 22 20 9 13 9 13 2"/></svg>' },
  { key: 'plumbing', name: 'Plumbing', tagline: 'Steady call volume and clear emergency intent. The fundamentals win this trade most of the time.', services: ['Service', 'Drain cleaning', 'Water heaters'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5c4 5.5 6.5 9 6.5 12.5a6.5 6.5 0 0 1-13 0c0-3.5 2.5-7 6.5-12.5z"/></svg>' },
  { key: 'hvac', name: 'HVAC', tagline: 'Seasonal spikes and high install value. Lead generation has to be on before the heat or the cold hits.', services: ['Service', 'Install', 'Heat pumps'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h13a3 3 0 1 0-3-3"/><path d="M3 16h17a3 3 0 1 1-3 3"/><path d="M3 12h11a3 3 0 1 1-3 3"/></svg>' },
  { key: 'landscaping', name: 'Landscaping', tagline: 'Design-build and maintenance both convert well online. We split campaigns to match how customers actually search.', services: ['Design', 'Hardscapes', 'Maintenance'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.96c1.4 9.3 4.8 15.4-4.4 18.8z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>' },
  { key: 'roofing', name: 'Roofing', tagline: 'Storm season is a sprint. We build campaigns that are ready before the storm and still working after the leads dry up.', services: ['Replacement', 'Repair', 'Storm restoration', 'Gutters'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8"/><path d="M5 9.5V21h14V9.5"/><path d="M9 21v-6h6v6"/></svg>' },
  { key: 'grading', name: 'Grading & excavation', tagline: 'High-ticket commercial and residential work. The site has to qualify leads or you waste days on bad jobs.', services: ['Site prep', 'Driveways', 'Demolition'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M5 20l3-7 4 2 3-5 4 3v7"/><circle cx="6.5" cy="20" r="1.5"/><circle cx="17.5" cy="20" r="1.5"/></svg>' },
  { key: 'garage-doors', name: 'Garage doors', tagline: 'Emergency repair plus high-margin installs. Phone-call volume is the whole game in this trade.', services: ['Springs', 'Openers', 'Panels', 'Install'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="1"/><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="13" x2="21" y2="13"/><line x1="3" y1="18" x2="21" y2="18"/></svg>' },
  { key: 'pressure-washing', name: 'Pressure washing', tagline: 'Easy to start, hard to scale. We stack recurring fleet and HOA contracts on top of one-off residential.', services: ['Residential', 'Fleet washing', 'HOA contracts', 'Soft wash'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M14 4v3a3 3 0 0 0 3 3h3"/><rect x="13" y="11" width="9" height="3" rx="0.5"/><path d="M3 14l5-3"/><path d="M3 17l5-2"/><path d="M3 20l5-1"/></svg>' },
  { key: 'fencing', name: 'Fencing', tagline: 'Quote-driven business with long sales cycles. The site has to qualify the lead so you are not driving to dead ones.', services: ['Wood', 'Vinyl', 'Chain link', 'Repairs'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="18" x2="21" y2="18"/><line x1="3" y1="14" x2="21" y2="14"/><path d="M5 8l1-3 1 3v14"/><path d="M9 8l1-3 1 3v14"/><path d="M13 8l1-3 1 3v14"/><path d="M17 8l1-3 1 3v14"/></svg>' },
  { key: 'concrete', name: 'Concrete & masonry', tagline: 'Photo-rich work that wins on visuals. We turn finished jobs into ranking pages and GBP posts that bring the next one in.', services: ['Driveways', 'Patios', 'Retaining walls', 'Repairs'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="0.5"/><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="16" x2="21" y2="16"/></svg>' },
  { key: 'house-painters', name: 'House painters', tagline: 'Repeat-customer business with strong before/after content. We rank the service pages and turn finished jobs into the next booking.', services: ['Interior', 'Exterior', 'Cabinet refinishing', 'Soft wash + paint'], icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="13" height="5" rx="1"/><path d="M16 6.5h4"/><path d="M20 5v3"/><path d="M10 9v3"/><rect x="7" y="12" width="6" height="9" rx="1"/></svg>' },
];

// Duplicate for marquee continuity
const marqueeRowA = [...trades, ...trades];
const marqueeRowB = [...trades.slice().reverse(), ...trades.slice().reverse()];
---

<BaseLayout title="Industries Section — Redesign Concepts" description="Preview comparison of redesign concepts for the industries section.">

  <section class="preview-intro">
    <div class="container">
      <h1>Industries section — three redesign directions.</h1>
      <p>House painters added to all three. Pick one, I'll ship it.</p>
    </div>
  </section>

  <!-- ============ CONCEPT A: CARD GRID ============ -->
  <section class="concept" id="a">
    <div class="container">
      <div class="concept-tag">Concept A · Card Grid</div>
      <h2>Every trade, equal weight.</h2>
      <p class="concept-desc">Flat 4-column grid. All 13 trades visible at once. Each card is self-contained, hover lifts, clicks anywhere on the card.</p>

      <div class="grid-a">
        {trades.map(t => (
          <a href="#contact" class="card-a">
            <div class="card-a-icon" set:html={t.icon}></div>
            <div class="card-a-name">{t.name}</div>
            <div class="card-a-tagline">{t.tagline}</div>
            <div class="card-a-chips">
              {t.services.map(s => <span class="card-a-chip">{s}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CONCEPT B: MARQUEE ============ -->
  <section class="concept dark" id="b">
    <div class="container">
      <div class="concept-tag">Concept B · Marquee</div>
      <h2>Two rows in motion.</h2>
      <p class="concept-desc">Compact tiles scroll past in opposite directions. Hover a tile to pause and read details below. Visual energy, holds the eye.</p>
    </div>

    <div class="marquee">
      <div class="marquee-row marquee-row-a">
        {marqueeRowA.map(t => (
          <button type="button" class="marquee-tile" data-trade={t.key}>
            <span class="marquee-tile-icon" set:html={t.icon}></span>
            <span class="marquee-tile-name">{t.name}</span>
          </button>
        ))}
      </div>
      <div class="marquee-row marquee-row-b">
        {marqueeRowB.map(t => (
          <button type="button" class="marquee-tile" data-trade={t.key}>
            <span class="marquee-tile-icon" set:html={t.icon}></span>
            <span class="marquee-tile-name">{t.name}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="container">
      <div class="marquee-detail" id="marquee-detail">
        <div class="md-icon" set:html={trades[0].icon}></div>
        <div class="md-body">
          <div class="md-name">{trades[0].name}</div>
          <div class="md-tagline">{trades[0].tagline}</div>
          <div class="md-chips">
            {trades[0].services.map(s => <span class="md-chip">{s}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CONCEPT C: ACCORDION ============ -->
  <section class="concept" id="c">
    <div class="container">
      <div class="concept-tag">Concept C · Accordion list</div>
      <h2>Compact list, expand on click.</h2>
      <p class="concept-desc">Single column of trades. Click a row to expand the tagline and sub-services inline. Reads like a directory, feels tight.</p>

      <div class="accordion">
        {trades.map((t, i) => (
          <details class="acc-row" open={i === 0}>
            <summary class="acc-summary">
              <span class="acc-icon" set:html={t.icon}></span>
              <span class="acc-name">{t.name}</span>
              <span class="acc-chev">+</span>
            </summary>
            <div class="acc-body">
              <p class="acc-tagline">{t.tagline}</p>
              <div class="acc-chips">
                {t.services.map(s => <span class="acc-chip">{s}</span>)}
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

<script>
  // Marquee detail panel update on hover
  const detail = document.getElementById('marquee-detail');
  const trades = {
    'tree-services': { name: 'Tree services', tagline: 'Highest-intent vertical in home services. Emergency work alone usually pays for the marketing.', services: ['Removal', 'Pruning', 'Stump grinding', 'Emergency'] },
    'land-management': { name: 'Land management', tagline: 'Big-ticket jobs with low search competition. The right pages and ads can dominate a 60-mile radius.', services: ['Forestry mulching', 'Clearing', 'Grading'] },
    'electrical': { name: 'Electrical', tagline: 'Mix of emergency, service, and big install work. Clear service pages convert calls fast.', services: ['Service', 'Repairs', 'Panel upgrades'] },
    'plumbing': { name: 'Plumbing', tagline: 'Steady call volume and clear emergency intent. The fundamentals win this trade most of the time.', services: ['Service', 'Drain cleaning', 'Water heaters'] },
    'hvac': { name: 'HVAC', tagline: 'Seasonal spikes and high install value. Lead generation has to be on before the heat or the cold hits.', services: ['Service', 'Install', 'Heat pumps'] },
    'landscaping': { name: 'Landscaping', tagline: 'Design-build and maintenance both convert well online. We split campaigns to match how customers actually search.', services: ['Design', 'Hardscapes', 'Maintenance'] },
    'roofing': { name: 'Roofing', tagline: 'Storm season is a sprint. We build campaigns that are ready before the storm and still working after the leads dry up.', services: ['Replacement', 'Repair', 'Storm restoration', 'Gutters'] },
    'grading': { name: 'Grading & excavation', tagline: 'High-ticket commercial and residential work. The site has to qualify leads or you waste days on bad jobs.', services: ['Site prep', 'Driveways', 'Demolition'] },
    'garage-doors': { name: 'Garage doors', tagline: 'Emergency repair plus high-margin installs. Phone-call volume is the whole game in this trade.', services: ['Springs', 'Openers', 'Panels', 'Install'] },
    'pressure-washing': { name: 'Pressure washing', tagline: 'Easy to start, hard to scale. We stack recurring fleet and HOA contracts on top of one-off residential.', services: ['Residential', 'Fleet washing', 'HOA contracts', 'Soft wash'] },
    'fencing': { name: 'Fencing', tagline: 'Quote-driven business with long sales cycles. The site has to qualify the lead so you are not driving to dead ones.', services: ['Wood', 'Vinyl', 'Chain link', 'Repairs'] },
    'concrete': { name: 'Concrete & masonry', tagline: 'Photo-rich work that wins on visuals. We turn finished jobs into ranking pages and GBP posts that bring the next one in.', services: ['Driveways', 'Patios', 'Retaining walls', 'Repairs'] },
    'house-painters': { name: 'House painters', tagline: 'Repeat-customer business with strong before/after content. We rank the service pages and turn finished jobs into the next booking.', services: ['Interior', 'Exterior', 'Cabinet refinishing', 'Soft wash + paint'] },
  };

  function setDetail(key) {
    const t = trades[key];
    if (!t || !detail) return;
    detail.querySelector('.md-name').textContent = t.name;
    detail.querySelector('.md-tagline').textContent = t.tagline;
    const chipsEl = detail.querySelector('.md-chips');
    chipsEl.innerHTML = t.services.map(s => '<span class="md-chip">' + s + '</span>').join('');
  }

  document.querySelectorAll('.marquee-tile').forEach(tile => {
    tile.addEventListener('mouseenter', () => setDetail(tile.dataset.trade));
    tile.addEventListener('focus', () => setDetail(tile.dataset.trade));
    tile.addEventListener('click', e => { e.preventDefault(); setDetail(tile.dataset.trade); });
  });
</script>

<style is:global>
  .preview-intro { padding: 80px 0 32px; background: var(--bone); border-bottom: 1px solid var(--border); }
  .preview-intro h1 { font-size: 42px; letter-spacing: -0.03em; font-weight: 700; margin-bottom: 8px; }
  .preview-intro p { color: var(--slate); font-size: 16px; }

  .concept { padding: 96px 0 88px; border-bottom: 1px solid var(--border); }
  .concept.dark { background: var(--onyx); color: var(--white); border-bottom-color: rgba(255,255,255,0.08); padding-bottom: 64px; }
  .concept-tag {
    display: inline-block;
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    color: var(--blaze);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 16px;
    padding: 6px 12px;
    border: 1px solid var(--blaze);
    border-radius: 3px;
  }
  .concept h2 { font-size: 40px; letter-spacing: -0.03em; font-weight: 700; margin-bottom: 8px; }
  .concept.dark h2 { color: var(--white); }
  .concept-desc { color: var(--slate); font-size: 16px; max-width: 720px; margin-bottom: 48px; line-height: 1.55; }
  .concept.dark .concept-desc { color: var(--slate-light); }

  /* ============ CONCEPT A: CARD GRID ============ */
  .grid-a {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .card-a {
    background: var(--white);
    border: 1px solid var(--onyx);
    border-radius: 10px;
    padding: 24px 22px;
    box-shadow: 4px 4px 0 0 var(--onyx);
    text-decoration: none;
    color: inherit;
    display: flex; flex-direction: column;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .card-a:hover { transform: translate(-2px, -2px); box-shadow: 7px 7px 0 0 var(--blaze); }
  .card-a-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: var(--bone);
    color: var(--blaze);
    display: inline-flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .card-a-icon svg { width: 20px; height: 20px; }
  .card-a-name {
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-bottom: 8px;
    color: var(--onyx);
  }
  .card-a-tagline {
    font-size: 13px;
    color: var(--slate);
    line-height: 1.5;
    margin-bottom: 14px;
    flex: 1;
  }
  .card-a-chips {
    display: flex; flex-wrap: wrap; gap: 6px;
    padding-top: 14px;
    border-top: 1px dashed var(--border);
  }
  .card-a-chip {
    font-family: 'Sora', sans-serif;
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--onyx);
    background: var(--bone);
    border: 1px solid var(--border-strong);
    padding: 4px 8px;
    border-radius: 4px;
    font-weight: 600;
  }
  @media (max-width: 1100px) { .grid-a { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 800px)  { .grid-a { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 500px)  { .grid-a { grid-template-columns: 1fr; } }

  /* ============ CONCEPT B: MARQUEE ============ */
  .marquee {
    margin: 24px 0 56px;
    overflow: hidden;
    position: relative;
  }
  .marquee::before, .marquee::after {
    content: ''; position: absolute; top: 0; bottom: 0; width: 120px; z-index: 2; pointer-events: none;
  }
  .marquee::before { left: 0; background: linear-gradient(to right, var(--onyx), transparent); }
  .marquee::after  { right: 0; background: linear-gradient(to left, var(--onyx), transparent); }

  .marquee-row {
    display: flex; gap: 14px;
    width: max-content;
    padding: 10px 0;
  }
  .marquee-row-a { animation: marquee-l 60s linear infinite; }
  .marquee-row-b { animation: marquee-r 75s linear infinite; margin-top: 6px; }
  @keyframes marquee-l { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @keyframes marquee-r { from { transform: translateX(-50%); } to { transform: translateX(0); } }
  .marquee:hover .marquee-row { animation-play-state: paused; }

  .marquee-tile {
    display: inline-flex; align-items: center; gap: 12px;
    padding: 14px 22px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 999px;
    color: var(--white);
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.005em;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.18s, border-color 0.18s, transform 0.18s;
  }
  .marquee-tile:hover { background: rgba(251,86,7,0.12); border-color: var(--blaze); transform: scale(1.02); }
  .marquee-tile-icon { display: inline-flex; color: var(--blaze); }
  .marquee-tile-icon svg { width: 18px; height: 18px; }

  .marquee-detail {
    display: grid; grid-template-columns: 64px 1fr;
    gap: 24px;
    padding: 32px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 12px;
    align-items: start;
  }
  .md-icon {
    width: 64px; height: 64px;
    border-radius: 12px;
    background: rgba(251,86,7,0.12);
    color: var(--blaze);
    display: inline-flex; align-items: center; justify-content: center;
  }
  .md-icon svg { width: 32px; height: 32px; }
  .md-name { font-size: 22px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; color: var(--white); }
  .md-tagline { color: var(--slate-light); font-size: 15px; line-height: 1.55; margin-bottom: 16px; }
  .md-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .md-chip {
    font-family: 'Sora', sans-serif;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--white);
    background: rgba(251,86,7,0.16);
    border: 1px solid rgba(251,86,7,0.32);
    padding: 5px 10px;
    border-radius: 4px;
    font-weight: 600;
  }

  /* ============ CONCEPT C: ACCORDION ============ */
  .accordion {
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    overflow: hidden;
    background: var(--white);
    box-shadow: 4px 4px 0 0 var(--onyx);
  }
  .acc-row { border-bottom: 1px solid var(--border); }
  .acc-row:last-child { border-bottom: 0; }
  .acc-row[open] { background: var(--bone); }
  .acc-summary {
    display: flex; align-items: center; gap: 16px;
    padding: 20px 24px;
    cursor: pointer;
    list-style: none;
    transition: background 0.15s;
  }
  .acc-summary::-webkit-details-marker { display: none; }
  .acc-row:not([open]) .acc-summary:hover { background: var(--bone); }
  .acc-icon {
    width: 36px; height: 36px;
    border-radius: 8px;
    background: var(--bone);
    color: var(--blaze);
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .acc-row[open] .acc-icon { background: var(--white); }
  .acc-icon svg { width: 20px; height: 20px; }
  .acc-name {
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--onyx);
    flex: 1;
  }
  .acc-chev {
    font-family: 'Sora', sans-serif;
    font-size: 20px;
    color: var(--blaze);
    font-weight: 700;
    transition: transform 0.2s;
  }
  .acc-row[open] .acc-chev { transform: rotate(45deg); }
  .acc-body { padding: 0 24px 22px 76px; }
  .acc-tagline { font-size: 14px; line-height: 1.55; color: var(--slate); margin-bottom: 14px; }
  .acc-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .acc-chip {
    font-family: 'Sora', sans-serif;
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--onyx);
    background: var(--white);
    border: 1px solid var(--border-strong);
    padding: 4px 8px;
    border-radius: 4px;
    font-weight: 600;
  }
  @media (max-width: 600px) {
    .acc-body { padding-left: 24px; }
    .concept h2 { font-size: 30px; }
    .preview-intro h1 { font-size: 30px; }
  }
</style>

</BaseLayout>
