---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import QuoteModal from '../components/QuoteModal.astro';

interface Props {
  title: string;
  description?: string;
  bodyClass?: string;
}

const { title, description = '22 Local Marketing builds the marketing engine for home service companies. SEO, Google Ads, websites, and reporting that ties every dollar to revenue.', bodyClass = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<slot name="head" />
</head>
<body class={bodyClass}>
  <Header />
  <slot />
  <Footer />
  <QuoteModal />
</body>
</html>
